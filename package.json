{
  "name": "qurra-boutique",
  "version": "1.0.0",
  "description": "Premium Libyan boutique - Flask + Node.js frontend tooling",
  "main": "app.py",
  "scripts": {
    "dev": "npm run build:dev -- --watch",
    "build": "npm run build:prod",
    "build:dev": "cross-env NODE_ENV=development webpack --mode development",
    "build:prod": "cross-env NODE_ENV=production webpack --mode production",
    "lint:css": "stylelint 'static/css/**/*.css' 2>/dev/null || echo 'stylelint not configured'",
    "lint:js": "eslint 'static/js/**/*.js' 2>/dev/null || echo 'eslint not configured'",
    "format": "prettier --write 'static/**/*.{css,js,html}'",
    "start": "flask run",
    "production": "gunicorn -w 4 -b 0.0.0.0:8000 wsgi:app"
  },
  "keywords": [
    "boutique",
    "libyan",
    "ecommerce",
    "flask",
    "tailwindcss"
  ],
  "author": "Qurra Team",
  "license": "MIT",
  "dependencies": {
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "babel-loader": "^9.1.3",
    "cross-env": "^10.1.0",
    "css-loader": "^6.8.1",
    "cssnano": "^6.0.2",
    "eslint": "^8.55.0",
    "file-loader": "^6.2.0",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss-loader": "^7.3.4",
    "prettier": "^3.1.1",
    "style-loader": "^3.3.3",
    "stylelint": "^16.3.1",
    "stylelint-config-standard": "^36.0.0",
    "terser-webpack-plugin": "^5.3.9",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
