# Flask Configuration
FLASK_DEBUG=False
FLASK_ENV=production
PORT=5000

# Database
# SQLite is used by default (qurra.db), uncomment for PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost/qurra

# Security (change these in production!)
SECRET_KEY=your-production-secret-key-here
SESSION_COOKIE_SECURE=True

# Optional
LOG_LEVEL=INFO
